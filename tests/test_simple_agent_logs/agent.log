def impacted_segments(remain, disruption_stops, pick_to_drop):
    out = {}
    for arc in (disruption_stops or []):
        prev_stop = arc.get("prev_stop_id")
        next_stop = arc.get("next_stop_id")
        if prev_stop is None or next_stop is None:
            continue

        drop_next = pick_to_drop.get(next_stop)
        if drop_next is None:
            continue

        for bid, route in (remain or {}).items():
            if bid in out or not route:
                continue

            # Guarded lookups
            try:
                i = route.index(prev_stop)
            except ValueError:
                continue
            if i + 1 >= len(route) or route[i + 1] != next_stop:
                continue
            try:
                k = route.index(drop_next, i + 2)  # first drop(next) after 'next'
            except ValueError:
                continue

            out[bid] = {
                "seg_start": i + 1,         # index of next_stop
                "seg_end":   k,             # index of drop(next)
                "boundary_drop": route[k],
                "next": next_stop,
                "prev": prev_stop,
            }
    return out
```

