def planned_time_lookup(time_windows, stop_id):
    "Can be used as a helper to get planned time for a stop"
    value = time_windows.get(stop_id, 0)
    if isinstance(value, (list, tuple)):
        value = value[0] if value else 0
    return float(value or 0)
